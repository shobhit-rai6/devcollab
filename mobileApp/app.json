{
  "expo": {
    "name": "DevCollab",
    "slug": "devcollab-rn",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#0a0b0f"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.devcollab.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0b0f"
      },
      "package": "com.devcollab.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
